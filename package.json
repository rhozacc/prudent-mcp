{
  "name": "prudent-mcp",
  "version": "0.5.0",
  "description": "MCP server exposing the prudent IRB validation knowledge base",
  "type": "module",
  "module": "src/server.ts",
  "main": "src/server.ts",
  "bin": {
    "prudent-mcp": "src/server.ts"
  },
  "exports": {
    ".": "./src/server.ts",
    "./schema": "./src/schema.ts",
    "./adapters": "./src/adapters.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "demo": "bun run examples/inmemory-demo.ts",
    "inspect": "bunx @modelcontextprotocol/inspector bun src/server.ts",
    "inspect:demo": "bunx @modelcontextprotocol/inspector bun examples/inmemory-demo.ts",
    "schemas": "bun run scripts/generate-schemas.ts && bun run scripts/generate-schema-docs.ts",
    "schema-docs": "bun run scripts/generate-schema-docs.ts",
    "list": "bun run scripts/list-all.ts",
    "validate": "bun run scripts/validate-corpus.ts",
    "graph": "bun run scripts/generate-graph.ts",
    "build:mcpb": "bun run scripts/build-mcpb.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "esbuild": "^0.24.0",
    "mermaid": "^11.15.0",
    "typescript": "^5.6.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "zod-to-json-schema": "^3.23.0"
  }
}
